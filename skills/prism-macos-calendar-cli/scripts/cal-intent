#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cal-intent "<natural language request>" [--format json|pretty]

Examples:
  ./scripts/cal-intent "明天看看会议"
  ./scripts/cal-intent "明天下午两点在工作日历创建评审会"
  ./scripts/cal-intent "把那个评审往后挪一点"
USAGE
}

if [[ $# -eq 0 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

request=""
format="json"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --format)
      format="${2:-json}"
      shift 2
      ;;
    *)
      if [[ -z "$request" ]]; then
        request="$1"
      else
        request="$request $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$request" ]]; then
  echo "Error: missing request text" >&2
  exit 2
fi

today="${PRISM_CALENDAR_INTENT_TODAY:-$(date '+%Y-%m-%d')}"
raw_tz="${PRISM_CALENDAR_TZ_OFFSET:-$(date '+%z')}"
if [[ "$raw_tz" =~ ^([+-][0-9]{2})([0-9]{2})$ ]]; then
  tz_offset="${BASH_REMATCH[1]}:${BASH_REMATCH[2]}"
else
  tz_offset="+08:00"
fi

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

to_json_field() {
  local value="$1"
  printf '"%s"' "$(json_escape "$value")"
}

date_shift_days() {
  local base="$1"
  local offset="$2"
  date -j -f "%Y-%m-%d" -v"${offset}"d "$base" "+%Y-%m-%d"
}

detect_intent() {
  local text="$1"
  if [[ "$text" == *"删除"* || "$text" == *"取消"* ]]; then
    printf '%s' "delete"
  elif [[ "$text" == *"修改"* || "$text" == *"推迟"* || "$text" == *"提前"* || "$text" == *"改到"* || "$text" == *"往后挪"* ]]; then
    printf '%s' "update"
  elif [[ "$text" == *"创建"* || "$text" == *"安排"* || "$text" == *"添加"* || "$text" == *"新建"* || "$text" == *"加一个日历"* || "$text" == *"加个日历"* || "$text" == *"加一个提醒"* || "$text" == *"加个提醒"* ]]; then
    printf '%s' "create"
  elif [[ "$text" == *"搜索"* || "$text" == *"查找"* || "$text" == *"找"* ]]; then
    printf '%s' "search"
  elif [[ "$text" == *"查看"* || "$text" == *"看看"* || "$text" == *"列出"* || "$text" == *"有哪些"* ]]; then
    printf '%s' "list"
  else
    printf '%s' "ambiguous"
  fi
}

detect_range() {
  local text="$1"
  if [[ "$text" == *"明天"* ]]; then
    printf '%s' "tomorrow"
  elif [[ "$text" == *"下周"* ]]; then
    printf '%s' "next7"
  elif [[ "$text" == *"今天"* ]]; then
    printf '%s' "today"
  else
    printf '%s' ""
  fi
}

detect_calendar() {
  local text="$1"
  local calendar=""
  local candidate=""

  if [[ "$text" == *"默认日历"* ]]; then
    printf '%s' "${PRISM_CALENDAR_DEFAULT:-}"
    return
  fi

  candidate="$(printf '%s' "$text" | sed -nE 's/.*[在到用]([^，。[:space:]]+)日历.*/\1/p' | head -n 1)"
  if [[ -n "$candidate" && ! "$candidate" =~ [0-9年月日点早上下晚中午] ]]; then
    calendar="$candidate"
  fi

  printf '%s' "$calendar"
}

normalize_hour() {
  case "$1" in
    0|零) printf '%s' "0" ;;
    1|一) printf '%s' "1" ;;
    2|二|两) printf '%s' "2" ;;
    3|三) printf '%s' "3" ;;
    4|四) printf '%s' "4" ;;
    5|五) printf '%s' "5" ;;
    6|六) printf '%s' "6" ;;
    7|七) printf '%s' "7" ;;
    8|八) printf '%s' "8" ;;
    9|九) printf '%s' "9" ;;
    10|十) printf '%s' "10" ;;
    11|十一) printf '%s' "11" ;;
    12|十二) printf '%s' "12" ;;
    *) printf '%s' "" ;;
  esac
}

detect_datetime() {
  local text="$1"
  local day="$today"
  local token=""
  local hour=""
  local explicit_year=""
  local explicit_month=""
  local explicit_day=""

  if [[ "$text" =~ ([0-9]{4})年([0-9]{1,2})月([0-9]{1,2})日 ]]; then
    explicit_year="${BASH_REMATCH[1]}"
    explicit_month="${BASH_REMATCH[2]}"
    explicit_day="${BASH_REMATCH[3]}"
    printf -v day '%04d-%02d-%02d' "$explicit_year" "$explicit_month" "$explicit_day"
  fi

  if [[ "$text" == *"明天"* ]]; then
    day="$(date_shift_days "$today" "+1")"
  elif [[ "$text" == *"今天"* ]]; then
    day="$today"
  fi

  if [[ "$text" =~ 下午([零一二两三四五六七八九十0-9]{1,3})点 ]]; then
    token="${BASH_REMATCH[1]}"
    hour="$(normalize_hour "$token")"
    if [[ -n "$hour" ]]; then
      hour=$((hour + 12))
    fi
  elif [[ "$text" =~ 晚上([零一二两三四五六七八九十0-9]{1,3})点 ]]; then
    token="${BASH_REMATCH[1]}"
    hour="$(normalize_hour "$token")"
    if [[ -n "$hour" && "$hour" -lt 12 ]]; then
      hour=$((hour + 12))
    fi
  elif [[ "$text" =~ 早上([零一二两三四五六七八九十0-9]{1,3})点 ]]; then
    token="${BASH_REMATCH[1]}"
    hour="$(normalize_hour "$token")"
  elif [[ "$text" =~ 上午([零一二两三四五六七八九十0-9]{1,3})点 ]]; then
    token="${BASH_REMATCH[1]}"
    hour="$(normalize_hour "$token")"
  elif [[ "$text" =~ ([零一二两三四五六七八九十0-9]{1,3})点 ]]; then
    token="${BASH_REMATCH[1]}"
    hour="$(normalize_hour "$token")"
  fi

  if [[ -z "$hour" ]]; then
    printf '%s\n%s' "" ""
    return
  fi

  printf -v start '%sT%02d:00:00%s' "$day" "$hour" "$tz_offset"
  printf -v end '%sT%02d:00:00%s' "$day" "$((hour + 1))" "$tz_offset"
  printf '%s\n%s' "$start" "$end"
}

extract_subject() {
  local text="$1"
  local reminder=""

  reminder="$(printf '%s' "$text" | sed -nE 's/.*(提醒我[^，。]+).*/\1/p' | head -n 1)"
  if [[ -n "$reminder" ]]; then
    printf '%s' "$reminder"
    return
  fi

  printf '%s' "$text" \
    | sed -E '
      s/在[0-9]{4}年[0-9]{1,2}月[0-9]{1,2}日//g;
      s/默认日历//g;
      s/在[^，。[:space:]]+日历//g;
      s/明天|今天|下周|下午|上午|早上|晚上|中午//g;
      s/[零一二两三四五六七八九十0-9]+点半?//g;
      s/创建|安排|添加|新建|删除|取消|搜索|查找|查看|看看|列出|有哪些|修改|推迟|提前|改到|往后挪|往后|加一个日历|加个日历|加一个提醒|加个提醒//g;
      s/一下|一点|把|那个//g;
      s/^，//g;
      s/[[:space:]]+//g;
    '
}

intent="$(detect_intent "$request")"
range_value="$(detect_range "$request")"
calendar_value="$(detect_calendar "$request")"
if [[ -z "$calendar_value" && "$intent" == "create" && -n "${PRISM_CALENDAR_DEFAULT:-}" ]]; then
  calendar_value="$PRISM_CALENDAR_DEFAULT"
fi
subject="$(extract_subject "$request")"
datetime_lines="$(detect_datetime "$request")"
start_value="${datetime_lines%%$'\n'*}"
end_value="${datetime_lines#*$'\n'}"
if [[ "$datetime_lines" != *$'\n'* ]]; then
  start_value=""
  end_value=""
fi

status="ambiguous"
confidence="low"
reason="无法从输入中确定意图"
next_command=""
query_value=""
title_value=""
range_for_search="$range_value"

if [[ -z "$range_for_search" ]]; then
  range_for_search="next7"
fi

case "$intent" in
  search)
    status="resolved"
    confidence="high"
    reason="已识别为搜索请求"
    query_value="$subject"
    next_command="./scripts/cal events search --query $query_value --range ${range_value:-next7} --format json"
    ;;
  list)
    if [[ -n "$subject" ]]; then
      status="resolved"
      confidence="medium"
      reason="已识别为带关键词的查看请求，转为搜索"
      intent="search"
      query_value="$subject"
      next_command="./scripts/cal events search --query $query_value --range ${range_value:-next7} --format json"
    else
      status="resolved"
      confidence="high"
      reason="已识别为列表请求"
      next_command="./scripts/cal events list --range ${range_value:-next7} --format json"
    fi
    ;;
  create)
    title_value="$subject"
    if [[ -n "$title_value" && -n "$start_value" && -n "$end_value" ]]; then
      status="resolved"
      confidence="high"
      reason="已识别为可执行的创建请求，默认先 dry-run"
      next_command="./scripts/cal events create"
      if [[ -n "$calendar_value" ]]; then
        next_command="$next_command --calendar $calendar_value"
      fi
      next_command="$next_command --title $title_value --start $start_value --end $end_value --format json"
    else
      status="ambiguous"
      confidence="low"
      reason="创建请求缺少可确定的标题或时间"
    fi
    ;;
  update|delete)
    query_value="$subject"
    if [[ -n "$query_value" ]]; then
      status="needs_search"
      confidence="medium"
      reason="写操作缺少唯一 selector，先搜索收敛候选"
      next_command="./scripts/cal events search --query $query_value --range $range_for_search --format json"
    else
      status="ambiguous"
      confidence="low"
      reason="写操作缺少可搜索的目标关键词"
    fi
    ;;
esac

if [[ "$format" == "pretty" ]]; then
  printf 'status: %s\nintent: %s\nconfidence: %s\nreason: %s\n' "$status" "$intent" "$confidence" "$reason"
  if [[ -n "$next_command" ]]; then
    printf 'next: %s\n' "$next_command"
  fi
  exit 0
fi

printf '{'
printf '"status":%s,' "$(to_json_field "$status")"
printf '"intent":%s,' "$(to_json_field "$intent")"
printf '"confidence":%s,' "$(to_json_field "$confidence")"
printf '"reason":%s,' "$(to_json_field "$reason")"
printf '"next_command":%s,' "$(to_json_field "$next_command")"
printf '"resolved_args":{'
printf '"calendar":%s,' "$(to_json_field "$calendar_value")"
printf '"id":"","uid":"",'
printf '"query":%s,' "$(to_json_field "$query_value")"
printf '"title":%s,' "$(to_json_field "$title_value")"
printf '"start":%s,' "$(to_json_field "$start_value")"
printf '"end":%s' "$(to_json_field "$end_value")"
printf '}}'
printf '\n'
