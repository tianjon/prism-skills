#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
backend="$script_dir/calendar.applescript"

usage() {
  cat <<'USAGE'
macOS Calendar CLI (Calendar.app automation)

Usage:
  cal --help
  cal doctor [--format json|pretty|text]
  cal calendars list [--format json|pretty|text]
  cal events list (--range <today|tomorrow|next7|thisweek|next30> | --from <ISO> --to <ISO>) \
    [--calendar <name>] [--limit <n>] [--format json|pretty|text]
  cal events search --query <text> (--range <...> | --from <ISO> --to <ISO>) \
    [--calendar <name>] [--limit <n>] [--format json|pretty|text]
  cal events create --calendar <name> --title <text> --start <ISO> --end <ISO> \
    [--location <text>] [--notes <text>] [--url <text>] [--apply] [--dry-run] [--format json|pretty|text]
  cal events update (--id <id> | --uid <uid>) [--calendar <name>] \
    [--title <text>] [--start <ISO>] [--end <ISO>] [--location <text>] [--notes <text>] [--url <text>] \
    [--apply] [--dry-run] [--format json|pretty|text]
  cal events delete (--id <id> | --uid <uid>) [--calendar <name>] [--apply] [--dry-run] [--format json|pretty|text]

Notes:
  - ISO examples: 2026-03-16, 2026-03-16T10:00, 2026-03-16T10:00:00+08:00
  - This tool may require macOS Automation permission for your terminal to control Calendar.app.
  - Write commands are safe by default: add --apply to actually modify Calendar.
  - Optional: set PRISM_CALENDAR_DEFAULT='<calendar name>' to avoid passing --calendar for events list/search/create.
USAGE
}

if [[ "${1:-}" == "--help" || "${1:-}" == "help" || "${1:-}" == "-h" || "$#" -eq 0 ]]; then
  usage
  exit 0
fi

expand_range() {
  local range="$1"
  local from=""
  local to=""
  local today
  today="$(date '+%Y-%m-%d')"

  case "$range" in
    today)
      from="$today"
      to="$today"
      ;;
    tomorrow)
      from="$(date -v+1d '+%Y-%m-%d')"
      to="$from"
      ;;
    next7)
      from="$today"
      to="$(date -v+6d '+%Y-%m-%d')"
      ;;
    next30)
      from="$today"
      to="$(date -v+29d '+%Y-%m-%d')"
      ;;
    thisweek)
      # Monday..Sunday (local time). BSD date: %u => 1..7 (Mon..Sun)
      local dow
      dow="$(date '+%u')"
      from="$(date -v-"$((dow-1))"d '+%Y-%m-%d')"
      to="$(date -v+"$((7-dow))"d '+%Y-%m-%d')"
      ;;
    *)
      echo "Error: invalid --range '$range' (expected today|tomorrow|next7|thisweek|next30)" >&2
      exit 2
      ;;
  esac

  printf '%s\n' "$from" "$to"
}

if [[ ! -f "$backend" ]]; then
  echo "Error: backend not found: $backend" >&2
  exit 2
fi

if [[ ! -x /usr/bin/osascript ]]; then
  echo "Error: /usr/bin/osascript not found or not executable" >&2
  exit 2
fi

# Forward user arguments as argv entries. Do not shell-interpolate user input.
expanded=("$@")
if [[ "${expanded[0]:-}" == "doctor" ]]; then
  expanded=("doctor" "run" "${expanded[@]:1}")
fi
if [[ "${expanded[0]:-}" == "events" && ( "${expanded[1]:-}" == "list" || "${expanded[1]:-}" == "search" ) ]]; then
  range=""
  has_from=0
  has_to=0
  out=()
  i=0
  while [[ $i -lt ${#expanded[@]} ]]; do
    tok="${expanded[$i]}"
    if [[ "$tok" == "--range" ]]; then
      range="${expanded[$((i+1))]:-}"
      i=$((i+2))
      continue
    fi
    if [[ "$tok" == "--from" ]]; then has_from=1; fi
    if [[ "$tok" == "--to" ]]; then has_to=1; fi
    out+=("$tok")
    i=$((i+1))
  done

  if [[ -n "$range" ]]; then
    if [[ $has_from -eq 1 || $has_to -eq 1 ]]; then
      echo "Error: use --range or --from/--to, not both" >&2
      exit 2
    fi
    range_out="$(expand_range "$range")"
    from="${range_out%%$'\n'*}"
    to="${range_out#*$'\n'}"
    out+=("--from" "$from" "--to" "$to")
  fi
  expanded=("${out[@]}")
fi

# Optional ergonomic default: inject --calendar if user didn't specify it.
if [[ -n "${PRISM_CALENDAR_DEFAULT:-}" && "${expanded[0]:-}" == "events" && ( "${expanded[1]:-}" == "list" || "${expanded[1]:-}" == "search" || "${expanded[1]:-}" == "create" ) ]]; then
  has_cal=0
  for tok in "${expanded[@]}"; do
    if [[ "$tok" == "--calendar" ]]; then
      has_cal=1
      break
    fi
  done
  if [[ $has_cal -eq 0 ]]; then
    expanded+=("--calendar" "$PRISM_CALENDAR_DEFAULT")
  fi
fi

/usr/bin/osascript "$backend" "${expanded[@]}"
